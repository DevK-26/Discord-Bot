# Copy this file to ".env" and fill in your real values.

# Your bot token from the Discord Developer Portal (Bot -> Reset Token -> Copy).
DISCORD_TOKEN=your-bot-token-here

# Database URL. SQLite by default; swap to PostgreSQL with no code changes, e.g.
#   DB_URL=postgresql+psycopg://user:password@localhost:5432/codesensei
DB_URL=sqlite:///app.db

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOGGING_LEVEL=INFO
# Rotating log file path.
LOG_FILE=bot.log

# Slash-command sync target. Set GUILD_ID to your test server's ID for INSTANT
# command updates during development (Server Settings -> Widget, or right-click
# the server icon with Developer Mode on -> Copy Server ID). Leave it BLANK to
# sync globally (works everywhere, but can take up to ~1 hour to appear).
GUILD_ID=

# Seconds the A/B/C/D answer buttons stay active before disabling and revealing
# the correct option.
ANSWER_TIMEOUT=120

# (Optional) Easter egg: a user ID that always gets auto-corrected answers + bonus
# aura. Leave blank to disable. Get an ID via Discord Developer Mode -> Copy User ID.
EASTER_EGG_USER_ID=
